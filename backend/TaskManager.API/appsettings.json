{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=taskmanagerdb;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200"
    ]
  },
  "Jwt": {
    "Issuer": "TaskManager.API",
    "Audience": "TaskManager.Frontend",
    "SigningKey": "task-manager-super-secret-signing-key-change-this",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30
  },
  "UseHttpsRedirection": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "AllowedHosts": "*"
}
